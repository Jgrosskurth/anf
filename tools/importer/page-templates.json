{
  "templates": [
    {
      "name": "homepage",
      "urls": [
        "https://web.archive.org/web/20260323180311/https://www.abercrombie.com/shop/us"
      ],
      "description": "Abercrombie & Fitch Spring 2026 homepage with hero carousel, editorial cards, heritage hero, YPB section, and services",
      "blocks": [
        {
          "name": "hero-banner",
          "instances": [
            ".promo-banner"
          ]
        },
        {
          "name": "carousel-nfl",
          "instances": [
            ".hero-carousel"
          ]
        },
        {
          "name": "cards-editorial",
          "instances": [
            ".editorial-cards"
          ]
        },
        {
          "name": "hero",
          "instances": [
            ".heritage-hero"
          ]
        },
        {
          "name": "hero-brand",
          "instances": [
            ".ypb-hero"
          ]
        },
        {
          "name": "columns-services",
          "instances": [
            ".services-section"
          ]
        }
      ],
      "sections": [
        {
          "id": "section-1",
          "name": "Promo Banner",
          "selector": ".promo-banner",
          "style": "dark",
          "blocks": ["hero-banner"],
          "defaultContent": []
        },
        {
          "id": "section-2",
          "name": "Hotel Abercrombie Carousel",
          "selector": ".hero-carousel",
          "style": null,
          "blocks": ["carousel-nfl"],
          "defaultContent": []
        },
        {
          "id": "section-3",
          "name": "Editorial Cards",
          "selector": ".editorial-cards",
          "style": null,
          "blocks": ["cards-editorial"],
          "defaultContent": []
        },
        {
          "id": "section-4",
          "name": "Heritage Collection Hero",
          "selector": ".heritage-hero",
          "style": null,
          "blocks": ["hero"],
          "defaultContent": []
        },
        {
          "id": "section-5",
          "name": "YPB Active Section",
          "selector": ".ypb-hero",
          "style": null,
          "blocks": ["hero-brand"],
          "defaultContent": []
        },
        {
          "id": "section-6",
          "name": "Membership & Services",
          "selector": ".services-section",
          "style": null,
          "blocks": ["columns-services"],
          "defaultContent": []
        }
      ]
    }
  ]
}
